{
  "name": "irogen-browser",
  "version": "0.1.0",
  "description": "Irogen browser WASM client",
  "main": "pkg/irogen_browser.js",
  "types": "pkg/irogen_browser.d.ts",
  "scripts": {
    "build:wasm:release": "cargo build --target=wasm32-unknown-unknown --release && wasm-bindgen ../target/wasm32-unknown-unknown/release/browser.wasm --out-dir=./pkg --weak-refs --target=web",
    "clean": "rm -rf pkg"
  }
}
